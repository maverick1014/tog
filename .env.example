# ---------------------------------------------------------------------------
# Supabase
# Get these from your Supabase project dashboard: Project Settings -> API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key is used by the NestJS API only (server-side, full access).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon/publishable key (safe for the browser if you later add RLS + auth).
SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# NestJS API (apps/api)
# ---------------------------------------------------------------------------
API_PORT=4000
# Comma separated list of allowed CORS origins for the API.
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Next.js web (apps/web)
# ---------------------------------------------------------------------------
# Base URL the browser uses to reach the NestJS API.
NEXT_PUBLIC_API_URL=http://localhost:4000
